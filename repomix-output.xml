        <th></th>
      </tr>
    </thead>
    <tbody>
      <tr
        *ngFor="let device of devices"
        (click)="goToDetails(device.id)"
        class="clickable-row"
      >
        <td>{{ device.name }}</td>
        <td>{{ device.manufacturer }}</td>
        <td>{{ device.type }}</td>
        <td>
          <span class="status-pill" [attr.data-status]="device.status">
            {{ device.status }}
          </span>
        </td>
        <td>
          <ng-container *ngIf="device.assignedUser; else noUser">
            {{ device.assignedUser.firstName }}
            {{ device.assignedUser.lastName }}
          </ng-container>

          <ng-template #noUser> -- </ng-template>
        </td>

        <td class="action-cell">
          <ng-container *ngIf="authService.isAdmin()">
            <button
              class="delete-btn"
              (click)="deleteDevice($event, device.id)"
            >
              Delete
            </button>
          </ng-container>

          <ng-container *ngIf="!authService.isAdmin()">
            <button
              *ngIf="device.status === 'Available'"
              class="assign-btn"
              (click)="assignToMe($event, device.id)"
            >
              Assign
            </button>

            <button
              *ngIf="device.status == 'In Use'"
              class="unassign-btn"
              (click)="unassign($event, device.id)"
            >
              Unassign
            </button>
          </ng-container>
        </td>
      </tr>
    </tbody>
  </table>
</div>
